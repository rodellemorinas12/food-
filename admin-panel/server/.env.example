# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=food_delivery_db
PORT=5000

# Email Configuration (Gmail)
# Note: Use an App Password, not your regular Gmail password
# Enable 2-Factor Authentication and generate an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Admin Security Token
# Use a strong random string for production
ADMIN_TOKEN=your-secure-admin-token-change-in-production
